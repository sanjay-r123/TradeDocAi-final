# ============================================================
# TradeDoc AI — Environment Configuration
# ============================================================
# Copy this to .env and fill in your actual values:
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows)
#
# Docker Compose reads these automatically from .env
# ============================================================

# ── Google Gemini AI ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# ── Adobe PDF Services (Word conversion) ────────────────────
# Get credentials at: https://developer.adobe.com/document-services/
PDF_SERVICES_CLIENT_ID=your_adobe_client_id_here
PDF_SERVICES_CLIENT_SECRET=your_adobe_client_secret_here

# ── MongoDB ─────────────────────────────────────────────────
# When running locally (outside Docker):
#   MONGO_URI=mongodb://localhost:27017/
# When running inside Docker Compose this is set automatically
#   to mongodb://mongo:27017/ via docker-compose.yml
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=tradedocai

# ── App Security / Runtime ─────────────────────────────────
APP_ENV=development
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_MAX_AGE_SECONDS=604800
ENABLE_DEMO_USER=true
DEMO_USER_EMAIL=demo@tradedoc.ai
DEMO_USER_PASSWORD=demo123
DEMO_USER_NAME=Demo User
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5055
MAX_CONTENT_LENGTH_BYTES=2097152
PDFLATEX_TIMEOUT_SECONDS=45
PDF_RETENTION_HOURS=24

# ── Google Cloud Storage (PDF archival) ─────────────────────
# Create a bucket at https://console.cloud.google.com/storage
GCS_BUCKET_NAME=tradedoc-pdfs
# Path to your service-account JSON key file (download from IAM → Service Accounts)
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account.json

# ── Production container runtime ────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
